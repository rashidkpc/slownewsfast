{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "slownewsfast",
	"compatibility_date": "2026-06-19",
	"main": "./worker/index.ts",
	"assets": {
		"not_found_handling": "single-page-application",
		"binding": "ASSETS",
		"run_worker_first": [
			"/api/*",
			"/feeds/*.xml",
			"/feeds/*/entries/*.html",
			"/files/*"
		]
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "slownewsfast-db",
			"database_id": "YOUR_DATABASE_ID",
			"migrations_dir": "migrations"
		}
	],
	"r2_buckets": [
		{
			"binding": "ATTACHMENTS",
			"bucket_name": "slownewsfast-attachments"
		}
	],
	"workers_dev": true,
	"vars": {
		"DOMAIN": "slownews.yourdomain.com"
	},
	"triggers": {
		"crons": [
			"0 * * * *"
		]
	},
	"observability": {
		"enabled": true
	}
}